        "target": {
          "query": "from(bucket: \"telemetry\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"car_telemetry\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"lap\")\r\n  |> map(fn: (r) => ({ r with current_lap: r._value }))\r\n  |> difference(columns: [\"_value\"])\r\n  |> filter(fn: (r) => r[\"_value\"] > 0)\r\n  |> map(fn: (r) => ({ _time: r._time, text: \"Lap \" + string(v: r.current_lap) }))",
          "refId": "Anno"
        }
      }
